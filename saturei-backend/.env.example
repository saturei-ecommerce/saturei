# ============================================================
# .env.example — copy to .env and fill in the values
# cp .env.example .env
# ============================================================
# NEVER commit the actual .env file to version control.
# ============================================================

# ──────────────────────────────────────────────
# Spring
# ──────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ──────────────────────────────────────────────
# Database — PostgreSQL
# On Render: use the internal connection URL from your Postgres instance.
# Format: jdbc:postgresql://<host>:<port>/<dbname>
# ──────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/saturei
DB_USERNAME=postgres
DB_PASSWORD=change_me_in_production

# ──────────────────────────────────────────────
# Application server
# ──────────────────────────────────────────────
SERVER_PORT=8080

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
JWT_SECRET=change_me_to_a_strong_random_secret_min_32_chars
JWT_ISSUER=saturei
JWT_EXPIRATION_TIME_IN_DAYS=7

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
# Options: ERROR, WARN, INFO, DEBUG, TRACE
LOG_LEVEL=INFO
LOG_LEVEL_SECURITY=WARN
